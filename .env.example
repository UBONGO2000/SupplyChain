# Environment Configuration
# ========================
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=mysql+pymysql://username:password@host:port/database_name

# Example for local MySQL:
# DATABASE_URL=mysql+pymysql://root:Mysql2026@localhost:3306/supply_chain_db

# Example for TiDB Cloud:
# DATABASE_URL=mysql+pymysql://user:password@gateway.region.prod.aws.tidbcloud.com:4000/supply_chain_db

# Security - JWT Secret Key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT Token Expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
